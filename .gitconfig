[user]
	email = ibeem@outlook.com
	name = ebeem
[core]
	autocrlf = input
	excludesfile = /home/ebeem/.gitignore_global
[http]
	sslverify = false
	proxy = 
[pull]
	rebase = false
[filter "lfs"]
	clean = git-lfs clean -- %f
	smudge = git-lfs smudge -- %f
	process = git-lfs filter-process
	required = true
